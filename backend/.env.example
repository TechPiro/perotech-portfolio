# ============================================================
#  PeroTech configuration — copy this file to ".env" and edit.
# ============================================================

# ============================================================
#  SERVER / PRODUCTION
# ============================================================
# PORT the Node app listens on (Nginx proxies 80/443 -> this).
PORT=5000
# Set to "production" when live.
NODE_ENV=production
# Your live site URL. IMPORTANT: this builds the absolute links used in
# newsletter emails (file downloads, video links). Set it to your real domain.
PUBLIC_URL=https://yourdomain.com

# ---- Persistent storage (PRODUCTION) ----
# Point these at folders OUTSIDE the git working tree so deployments never
# overwrite or delete live data/uploads. Leave them unset in local development
# (they default to backend/data and frontend/assets/uploads).
# DATA_DIR=/srv/perotech/data
# UPLOAD_DIR=/srv/perotech/uploads

# ============================================================
#  ADMIN LOGIN  (change these before going live!)
# ============================================================
ADMIN_USER=admin
ADMIN_PASS=change-this-password
# Long random string used to sign admin sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SECRET=change-this-to-a-long-random-string

# ============================================================
#  MAIL — common to every provider
# ============================================================
MAIL_FROM_NAME=PeroTech Newsletter
MAIL_FROM_EMAIL=you@yourdomain.com
NOTIFY_EMAIL=you@yourdomain.com        # optional: alerts you on each new subscriber

# ============================================================
#  OPTION 1 — Gmail (good for testing)
#  Requires 2-Step Verification ON, then create an "App Password":
#  Google Account > Security > 2-Step Verification > App passwords.
#  Use that 16-character app password (NOT your normal password).
#  Use port 465 (SSL) — some networks/hosts block 587.
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-16-char-app-password

# ============================================================
#  OPTION 2 — Resend (recommended for production deliverability)
#  Verify your domain in Resend, then:
# ------------------------------------------------------------
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=your-resend-api-key

# ============================================================
#  OPTION 3 — SendGrid
# ------------------------------------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# ============================================================
#  OPTION 4 — Your own / company SMTP
# ------------------------------------------------------------
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465           # 465 = SSL, 587 = STARTTLS
# SMTP_USER=newsletter@yourdomain.com
# SMTP_PASS=your-mailbox-password

# ------------------------------------------------------------
#  Tip: if you leave SMTP_* blank/unset, the server runs in
#  TEST mode (Ethereal preview links) and won't send real mail.
# ============================================================
